  file_change {
    absolute_path_uri: "file:///components/dashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "\'use client\';\nimport { useState, useEffect } from \'react\';\nimport { ActivityLog, Challenge, INITIAL_CHALLENGES } from \'@/lib/ecotrack\';\nimport ActivityForm from \'./activity-form\';\nimport AiCoach from \'./ai-coach\';\nimport dynamic from \'next/dynamic\';\nimport { Leaf, Trophy, Target, TrendingDown } from \'lucide-react\';\n\n// Disable SSR for charts to avoid hydration mismatch with recharts\nconst CarbonChart = dynamic(() => import(\'./carbon-chart\'), { ssr: false });\n\nexport function Dashboard() {\n  const [activities, setActivities] = useState<ActivityLog[]>([]);\n  const [challenges, setChallenges] = useState<Challenge[]>(INITIAL_CHALLENGES);\n  const [mounted, setMounted] = useState(false);\n\n  useEffect(() => {\n    setMounted(true);\n    const storedActs = localStorage.getItem(\'eco_activities\');\n    const storedChalls = localStorage.getItem(\'eco_challenges\');\n    if (storedActs) setActivities(JSON.parse(storedActs));\n    if (storedChalls) setChallenges(JSON.parse(storedChalls));\n  }, []);\n\n  useEffect(() => {\n    if (mounted) {\n      localStorage.setItem(\'eco_activities\', JSON.stringify(activities));\n      localStorage.setItem(\'eco_challenges\', JSON.stringify(challenges));\n    }\n  }, [activities, challenges, mounted]);\n\n  const totalCo2 = activities.reduce((sum, a) => sum + a.co2, 0);\n  const totalPoints = challenges.filter(c => c.completed).reduce((sum, c) => sum + c.points, 0);\n\n  const handleAddActivity = (act: ActivityLog) => {\n    setActivities(prev => [act, ...prev]);\n  };\n\n  const toggleChallenge = (id: string) => {\n    setChallenges(prev => prev.map(c => c.id === id ? { ...c, completed: !c.completed } : c));\n  };\n\n  if (!mounted) return <div className=\"min-h-screen bg-slate-50 flex items-center justify-center\">Loading...</div>;\n\n  return (\n    <div className=\"max-w-7xl mx-auto p-4 sm:p-6 lg:p-8 space-y-8\">\n      {/* Header */}\n      <header className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 bg-white p-6 sm:px-8 rounded-2xl shadow-sm border border-slate-100\">\n        <div className=\"flex items-center gap-4\">\n          <div className=\"p-3 bg-emerald-100 text-emerald-600 rounded-xl\">\n            <Leaf className=\"w-8 h-8\" />\n          </div>\n          <div>\n            <h1 className=\"text-2xl font-bold text-slate-800 tracking-tight\">EcoTrack AI</h1>\n            <p className=\"text-slate-500\">Your Personal Carbon Awareness Dashboard</p>\n          </div>\n        </div>\n        <div className=\"flex flex-wrap gap-4 w-full sm:w-auto\">\n          <div className=\"flex-1 sm:flex-none flex items-center gap-3 bg-slate-50 px-5 py-3 rounded-xl border border-slate-100\">\n            <Target className=\"w-6 h-6 text-blue-500\" />\n            <div>\n              <div className=\"text-xs text-slate-500 font-medium\">Total CO\342\202\202 Logged</div>\n              <div className=\"text-xl font-bold text-slate-800\">{totalCo2.toFixed(1)} <span className=\"text-sm font-medium text-slate-500\">kg</span></div>\n            </div>\n          </div>\n          <div className=\"flex-1 sm:flex-none flex items-center gap-3 bg-emerald-50 px-5 py-3 rounded-xl border border-emerald-100\">\n            <Trophy className=\"w-6 h-6 text-emerald-500\" />\n            <div>\n              <div className=\"text-xs text-emerald-700 font-medium\">Eco Points</div>\n              <div className=\"text-xl font-bold text-emerald-800\">{totalPoints}</div>\n            </div>\n          </div>\n        </div>\n      </header>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\n        <div className=\"lg:col-span-2 space-y-8\">\n            {/* Quick Actions & Challenges Grid */}\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n              <ActivityForm onAdd={handleAddActivity} />\n              \n              <div className=\"bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col h-full\">\n                <h2 className=\"text-lg font-bold text-slate-800 mb-4 flex items-center gap-2 shrink-0\">\n                    <TrendingDown className=\"w-5 h-5 text-emerald-500\" />\n                    Active Challenges\n                </h2>\n                <div className=\"space-y-3 flex-1 overflow-y-auto pr-2 custom-scrollbar\">\n                    {challenges.map(c => (\n                        <label key={c.id} className={`flex items-start gap-4 p-4 rounded-xl border transition-colors cursor-pointer ${c.completed ? \'border-emerald-200 bg-emerald-50/50\' : \'border-slate-100 hover:bg-slate-50\'}`}>\n                            <div className=\"pt-0.5\">\n                                <input\n                                    type=\"checkbox\"\n                                    checked={c.completed}\n                                    onChange={() => toggleChallenge(c.id)}\n                                    className=\"w-5 h-5 rounded border-slate-300 text-emerald-500 focus:ring-emerald-500 cursor-pointer\"\n                                />\n                            </div>\n                            <div className=\"flex-1\">\n                                <div className=\"flex justify-between items-start gap-2\">\n                                    <span className={`font-semibold ${c.completed ? \'text-slate-500 line-through\' : \'text-slate-800\'}`}>{c.title}</span>\n                                    <span className={`text-xs font-bold px-2.5 py-1 rounded-full whitespace-nowrap ${c.completed ? \'bg-emerald-200/50 text-emerald-700\' : \'bg-emerald-100 text-emerald-600\'}`}>+{c.points} pts</span>\n                                </div>\n                                <p className={`text-sm mt-1 leading-snug ${c.completed ? \'text-slate-400\' : \'text-slate-500\'}`}>{c.description}</p>\n                            </div>\n                        </label>\n                    ))}\n                </div>\n              </div>\n            </div>\n\n            {/* Chart Area */}\n            <div className=\"bg-white p-6 rounded-2xl shadow-sm border border-slate-100\">\n                <h2 className=\"text-lg font-bold text-slate-800 mb-6 flex items-center gap-2\">\n                    Emissions Overview (Last 7 Days)\n                </h2>\n                <div className=\"h-[300px] w-full\">\n                    <CarbonChart activities={activities} />\n                </div>\n            </div>\n        </div>\n\n        {/* Sidebar AI Chat */}\n        <div className=\"lg:col-span-1\">\n            <AiCoach />\n        </div>\n      </div>\n    </div>\n  );\n}"
    }
