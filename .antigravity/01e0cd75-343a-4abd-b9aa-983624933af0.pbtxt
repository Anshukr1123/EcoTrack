    replacement_chunks {
      replacement_content: "\'use client\';\nimport { ActivityLog } from \'@/lib/ecotrack\';\nimport { BarChart as RechartsBarChart, Bar, XAxis, YAxis, Tooltip, ResponsiveContainer, CartesianGrid } from \'recharts\';\nimport { format, subDays, startOfDay } from \'date-fns\';\nimport { BarChart } from \'lucide-react\';\n\nexport default function CarbonChart({ activities }: { activities: ActivityLog[] }) {\n  // Group last 7 days\n  const data = [];\n  for (let i = 6; i >= 0; i--) {\n    const date = startOfDay(subDays(new Date(), i));\n    const dayActivities = activities.filter(a => startOfDay(new Date(a.date)).getTime() === date.getTime());\n    const totalCo2 = dayActivities.reduce((sum, a) => sum + a.co2, 0);\n    data.push({\n      day: format(date, \'MMM dd\'),\n      co2: Number(totalCo2.toFixed(1))\n    });\n  }\n\n  if (activities.length === 0) {\n    return (\n        <div className=\"h-full flex flex-col items-center justify-center text-slate-400\">\n            <BarChart className=\"w-12 h-12 mb-2 opacity-20\" />\n            <p>No footprint data yet.</p>\n            <p className=\"text-sm\">Log activities to see your trends.</p>\n        </div>\n    );\n  }\n\n  return (\n    <ResponsiveContainer width=\"100%\" height=\"100%\">\n      <RechartsBarChart data={data} margin={{ top: 10, right: 10, left: -20, bottom: 0 }}>\n        <CartesianGrid strokeDasharray=\"3 3\" vertical={false} stroke=\"#e2e8f0\" />\n        <XAxis dataKey=\"day\" axisLine={false} tickLine={false} tick={{ fill: \'#64748b\', fontSize: 12 }} />\n        <YAxis axisLine={false} tickLine={false} tick={{ fill: \'#64748b\', fontSize: 12 }} />\n        <Tooltip\n          cursor={{ fill: \'#f1f5f9\' }}\n          contentStyle={{ borderRadius: \'8px\', border: \'none\', boxShadow: \'0 4px 6px -1px rgb(0 0 0 / 0.1)\' }}\n        />\n        <Bar dataKey=\"co2\" fill=\"#10b981\" radius={[4, 4, 0, 0]} name=\"CO\342\202\202 (kg)\" />\n      </RechartsBarChart>\n    </ResponsiveContainer>\n  );\n}"
    }
